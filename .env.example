# ============================================================
# Agent Swarm — Environment Variables
# Copy to .env and fill in your keys
# ============================================================

# TIER 1: FREE — Groq (get key at console.groq.com)
GROQ_API_KEY=gsk_your_groq_key_here

# TIER 1.5: DO Gradient (uses your DigitalOcean account)
DO_GRADIENT_API_KEY=your_do_gradient_key_here

# TIER 2: DeepSeek (get key at platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your_deepseek_key_here

# TIER 2: Mistral (get key at console.mistral.ai)
MISTRAL_API_KEY=your_mistral_key_here

# TIER 2: OpenRouter (get key at openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# TIER 3: Anthropic (get key at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# OPTIONAL: Slack webhook for agent alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
